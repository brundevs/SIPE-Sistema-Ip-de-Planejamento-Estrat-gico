# ─────────────────────────────────────────────────────────────
# SIPE | Sistema Ipê de Planejamento Estratégico
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────

# Flask
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-segura-de-32-bytes

# Modo debug (True apenas em desenvolvimento)
DEBUG=False

# Banco de dados (padrão: SQLite local)
# Para PostgreSQL em produção:
# DATABASE_URL=postgresql://user:password@localhost:5432/sipe
